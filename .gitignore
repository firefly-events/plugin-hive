.pHive/*
# Legacy state/ — ignored completely. Harness sessions running the pre-rename
# Stop hook may briefly recreate state/interrupts/ files until the session
# restarts. Keeping state/ ignored prevents those files from polluting PRs.
state/
# meta-team state, team configs, and team-memories are plugin-level and should be tracked
!.pHive/meta-team/
!.pHive/meta-team/**
!.pHive/teams/
!.pHive/teams/**
!.pHive/team-memories/
!.pHive/team-memories/**
# Meta-improvement-system epic artifacts (planning + audit trail for maintainer tooling).
# The parent .pHive/epics/ and .pHive/episodes/ dirs must be un-ignored first —
# git will not recurse into an ignored directory even if a deeper negation exists.
!.pHive/epics/
!.pHive/episodes/
# Then re-ignore every child of those dirs except the meta-improvement-system subtree.
.pHive/epics/*
.pHive/episodes/*
!.pHive/epics/meta-improvement-system/
!.pHive/epics/meta-improvement-system/**
!.pHive/episodes/meta-improvement-system/
!.pHive/episodes/meta-improvement-system/**
# Per-epic cycle-state lives under .pHive/cycle-state/; only the
# meta-improvement-system entry is tracked at this time (same maintainer-
# infrastructure rationale as the epics/ and episodes/ subtrees above).
!.pHive/cycle-state/
.pHive/cycle-state/*
!.pHive/cycle-state/meta-improvement-system.yaml
# Metrics carrier (.pHive/metrics/) — authored by S2 stories of the
# meta-improvement-system epic; contains schema docs and, from C1.4 on,
# fixtures consumed by hive/lib/metrics/ unit tests.
!.pHive/metrics/
!.pHive/metrics/**
# MVL proof artifacts — only the canonical mvl-proof folder ships with the repo.
!.pHive/audits/
.pHive/audits/*
!.pHive/audits/mvl-proof/
!.pHive/audits/mvl-proof/**
!.pHive/audits/mvs-proof/
!.pHive/audits/mvs-proof/**
agents/memories/
.claude/settings.local.json
.history/
.DS_Store
*.log
.claude/*.lock
# Python bytecode/caches — C1.4 (hive/lib/metrics/) introduced Python 3 runtime
# primitives with stdlib-only deps. Prevent __pycache__/ and *.pyc files from
# polluting the tree as future maintainer tooling adds more Python.
__pycache__/
*.pyc
*.pyo
